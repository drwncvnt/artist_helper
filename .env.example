# Copy this file to .env and fill in real values. Never commit .env.
#
# Generate strong secrets, e.g.:
#   openssl rand -hex 32

# Postgres password for the platform database.
POSTGRES_PASSWORD=

# Secret used to sign session tokens (JWT). Must be long and random.
# The gateway and accounts service share this value.
JWT_SECRET=

# Secret used by the beats tool to sign time-limited track streaming tokens.
SIGNING_SECRET=

# Upload size cap (MB) for the beats tool (optional; default 200).
BEATS_MAX_UPLOAD_MB=200

# Audio -> MIDI tool limits (optional; defaults shown). Clips are capped by both
# size and length to keep each transcription bounded.
TRANSCRIBE_MAX_UPLOAD_MB=25
TRANSCRIBE_MAX_DURATION_SECONDS=60

# Audio Analyzer tool limits (optional; defaults shown).
ANALYZER_MAX_UPLOAD_MB=40
ANALYZER_MAX_DURATION_SECONDS=300

# Name of the shared session cookie (optional; default shown).
SESSION_COOKIE_NAME=dp_session

# Session lifetime in seconds (optional; default 30 days).
SESSION_TTL_SECONDS=2592000

# Set to "true" in any real (HTTPS) deployment so the session cookie is only
# sent over TLS. Keep "false" only for local http:// testing.
COOKIE_SECURE=false

# Host port the gateway is published on (optional; default 4000).
GATEWAY_PORT=4000
